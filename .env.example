# App
NODE_ENV=production
APP_PORT=3000
NUXT_PUBLIC_APP_NAME="Quiniela Mundial 2026"

# Use at least 32 random characters. Example:
# openssl rand -hex 32
SESSION_SECRET="change-me-use-openssl-rand-hex-32"

# MongoDB used by Nuxt in Docker Compose.
# docker-compose.yml also builds this value automatically for the app service.
MONGODB_URI="mongodb://quiniela_app:change-me-app-password@mongo:27017/worldcup?authSource=worldcup"

# MongoDB container bootstrap
MONGO_DATABASE=worldcup
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD="change-me-root-password"
MONGO_APP_USERNAME=quiniela_app
MONGO_APP_PASSWORD="change-me-app-password"

# Optional seed values for initial admin
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD="change-me-admin-password"
