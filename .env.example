# App
NODE_ENV=production
APP_PORT=3000
BUILD_NODE_MEMORY_MB=2048
NUXT_PUBLIC_APP_NAME="Quiniela Mundial 2026"

# Use at least 32 random characters. Example:
# openssl rand -hex 32
SESSION_SECRET="change-me-use-openssl-rand-hex-32"

# External MongoDB connection used by Nuxt/EasyPanel.
# Examples:
# MONGODB_URI="mongodb://user:password@mongo-host:27017/worldcup?authSource=admin"
# MONGODB_URI="mongodb+srv://user:password@cluster.example.mongodb.net/worldcup?retryWrites=true&w=majority"
MONGODB_URI="mongodb://noevidal:Aguilar3@database_mongo_world-cup:27017/?tls=false"

# Optional seed values for initial admin
SEED_ADMIN_ENABLED=false
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD="change-me-admin-password"
